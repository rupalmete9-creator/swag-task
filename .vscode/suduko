<!DOCTYPE html>
<html>
<head>
<title>Sudoku Solver & Generator</title>
<style>
body {
  font-family: Arial;
  text-align: center;
  background: #f4f4f4;
}

#board {
  display: grid;
  grid-template-columns: repeat(9, 50px);
  grid-template-rows: repeat(9, 50px);
  margin: 20px auto;
  width: 450px;
}

.cell {
  border: 1px solid #999;
  font-size: 20px;
  text-align: center;
  line-height: 50px;
  cursor: pointer;
  background: white;
}

.cell:nth-child(3n) {
  border-right: 2px solid black;
}

.cell:nth-child(n+19):nth-child(-n+27),
.cell:nth-child(n+46):nth-child(-n+54) {
  border-bottom: 2px solid black;
}

.highlight {
  background: #d4f8d4;
}

.error {
  background: #ffb3b3;
}

button {
  margin: 10px;
  padding: 10px 20px;
}
</style>
</head>

<body>

<h2>Sudoku Solver & Generator</h2>

<div id="board"></div>

<button onclick="solveSudoku()">Solve</button>
<button onclick="generateSudoku()">Generate</button>

<script>

let board = [];
let cells = [];
let size = 9;

// ---------- CREATE GRID ----------
function createBoard() {
  const boardDiv = document.getElementById("board");
  boardDiv.innerHTML = "";
  board = [];
  cells = [];

  for (let row = 0; row < size; row++) {
    board[row] = [];
    for (let col = 0; col < size; col++) {

      board[row][col] = 0;

      const cell = document.createElement("div");
      cell.classList.add("cell");
      cell.contentEditable = true;

      cell.addEventListener("input", () => {
        let value = parseInt(cell.innerText);
        if (value >= 1 && value <= 9) {
          board[row][col] = value;
          if (!isValid(board, row, col, value)) {
            cell.classList.add("error");
          } else {
            cell.classList.remove("error");
          }
        } else {
          board[row][col] = 0;
          cell.innerText = "";
        }
      });

      boardDiv.appendChild(cell);
      cells.push(cell);
    }
  }
}

// ---------- CHECK VALID ----------
function isValid(board, row, col, num) {

  for (let i = 0; i < 9; i++) {
    if (i !== col && board[row][i] === num) return false;
    if (i !== row && board[i][col] === num) return false;
  }

  let startRow = row - row % 3;
  let startCol = col - col % 3;

  for (let r = 0; r < 3; r++) {
    for (let c = 0; c < 3; c++) {
      if ((startRow + r !== row || startCol + c !== col) &&
          board[startRow + r][startCol + c] === num) {
        return false;
      }
    }
  }

  return true;
}

// ---------- FIND EMPTY ----------
function findEmpty(board) {
  for (let r = 0; r < 9; r++) {
    for (let c = 0; c < 9; c++) {
      if (board[r][c] === 0) return [r, c];
    }
  }
  return null;
}

// ---------- SOLVER (BACKTRACKING) ----------
async function solve(board) {

  let empty = findEmpty(board);
  if (!empty) return true;

  let row = empty[0];
  let col = empty[1];

  for (let num = 1; num <= 9; num++) {

    if (isValid(board, row, col, num)) {

      board[row][col] = num;
      updateUI();

      await sleep(30);

      if (await solve(board)) return true;

      board[row][col] = 0;
      updateUI();
      await sleep(30);
    }
  }

  return false;
}

// ---------- UPDATE UI ----------
function updateUI() {
  for (let i = 0; i < 81; i++) {
    let r = Math.floor(i / 9);
    let c = i % 9;
    cells[i].innerText = board[r][c] === 0 ? "" : board[r][c];
  }
}

// ---------- SLEEP (Animation Delay) ----------
function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

// ---------- BUTTON SOLVE ----------
function solveSudoku() {
  solve(board);
}

// ---------- GENERATOR ----------
async function generateSudoku() {

  createBoard();

  await solve(board);

  let remove = 45; // difficulty

  while (remove > 0) {
    let r = Math.floor(Math.random() * 9);
    let c = Math.floor(Math.random() * 9);

    if (board[r][c] !== 0) {
      board[r][c] = 0;
      remove--;
    }
  }

  updateUI();
}

// ---------- INIT ----------
createBoard();

</script>
</body>
</html>